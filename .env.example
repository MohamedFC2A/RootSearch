# ==============================================================================
# FUCKEN SEARCH - Environment Variables Template
# قم بنسخ هذا الملف إلى ملف جديد باسم .env وتعديل القيم بما يناسب احتياجاتك
# ==============================================================================

# منفذ الخادم ومضيف التشغيل محلياً
HOST=0.0.0.0
PORT=6969
DEBUG=False

# مزود الذكاء الاصطناعي الافتراضي للتحليل والتلخيص
# الخيارات المتاحة: 
# 1. gemini (يستخدم Google Gemini API)
# 2. glm_colab (يستخدم نموذج GLM المستضاف على Google Colab)
LLM_PROVIDER=gemini

# ------------------------------------------------------------------------------
# إعدادات Google Gemini API
# ------------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# إعدادات نموذج GLM-4 المستضاف على Google Colab
# ------------------------------------------------------------------------------
# ضع هنا الرابط العام الذي يوفره Cloudflare Tunnel من نوت بوك Colab
GLM_API_URL=https://xxxx-xxxx-xxxx.trycloudflare.com
# مفتاح اختياري لحماية خادم Colab الخاص بك (إذا تم تعيينه في كود Colab)
GLM_API_KEY=
