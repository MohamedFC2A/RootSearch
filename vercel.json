{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": null,
  "installCommand": null,
  "rewrites": [
    { "source": "/", "destination": "/web/templates/index.html" },
    { "source": "/static/(.*)", "destination": "/web/static/$1" }
  ],
  "headers": [
    {
      "source": "/web/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
