# pyenv
#   For a library or app, you might want to share your .python-version if you're
#   using pyenv and micro-projects.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a multi-platform environment, the lock file may not be portable.
#Pipfile.lock

# poetry
#   Poetry uses pyproject.toml to define dependencies, and poetry.lock to lock them.
#   poetry.lock should be tracked in version control.
#poetry.lock

# pdm
#   PDM stores project-wide configurations in .pdm.toml
.pdm.toml
#   and local configurations in .pdm-python.path of project root
.pdm-python.path
